{
  "name": "fitness-app",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "fitness-app/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/fitness-app",
        "index": "fitness-app/src/index.html",
        "browser": "fitness-app/src/main.ts",
        "tsConfig": "fitness-app/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "fitness-app/public"
          }
        ],
        "styles": ["node_modules/primeicons/primeicons.css",
  "fitness-app/src/styles.css"],
        "server": "fitness-app/src/main.server.ts",
        "ssr": {
          "entry": "fitness-app/src/server.ts"
        },
        "outputMode": "server"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "fitness-app:build:production"
        },
        "development": {
          "buildTarget": "fitness-app:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "fitness-app:build",
        "port": 4200,
        "staticFilePath": "dist/fitness-app/browser",
        "spa": true
      }
    }
  }
}
